# ⚠️  SECURITY WARNING: API KEYS EXPOSED IN THIS FILE ⚠️
# This file contains placeholder values only - DO NOT put real API keys here
# Real API keys are stored securely in Supabase Edge Function secrets

# Anam.ai API Configuration
# Get your API key from: https://dashboard.anam.ai/
# Store the real key in Supabase secrets as ANAM_API_KEY (not in this file)
VITE_ANAM_API_KEY='your_anam_api_key_here_placeholder_only'

# OpenAI API Configuration  
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Environment Configuration
NODE_ENV=development

# Site availability — set to 'true' to show the maintenance/shutdown page to all users
VITE_SITE_DOWN=false

# Admin email that can bypass the VITE_SITE_DOWN gate (comma-separated for multiple)
VITE_ADMIN_BYPASS_EMAIL=founders@intrvue.ai

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control
# 4. Keep your API keys secure and private

# Note: API keys should be kept secure on your server
# The anam.ai integration requires server-side token generation
# to keep your API key safe from client-side exposure